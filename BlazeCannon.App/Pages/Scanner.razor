@page "/scanner"
@using BlazeCannon.App.Services
@using BlazeCannon.Core.Interfaces
@using BlazeCannon.Core.Models
@inject AppStateService AppState
@inject IVulnerabilityScanner VulnScanner
@implements IDisposable

<PageTitle>Scanner - BlazeCannon</PageTitle>

<h2>Vulnerability Scanner</h2>

<div class="scanner-layout">
    <div class="scan-config">
        <h4>Scan Configuration</h4>
        <div class="form-group">
            <label>Target Pages (one per line)</label>
            <textarea @bind="_targetPages" class="form-control dark-input" rows="5" placeholder="/login&#10;/search&#10;/guestbook&#10;/dns-lookup"></textarea>
        </div>

        <div class="form-group">
            <label>Vulnerability Categories</label>
            <div class="category-checks">
                <label><input type="checkbox" @bind="_enableXss" /> XSS</label>
                <label><input type="checkbox" @bind="_enableSqli" /> SQL Injection</label>
                <label><input type="checkbox" @bind="_enableCmdInj" /> Command Injection</label>
                <label><input type="checkbox" @bind="_enablePathTrav" /> Path Traversal</label>
            </div>
        </div>

        <div class="form-group">
            <label>Delay between payloads (ms)</label>
            <input type="number" @bind="_delayMs" class="form-control dark-input" />
        </div>

        @if (_progress?.Status == ScanStatus.Scanning)
        {
            <button class="btn btn-danger" @onclick="CancelScan">Cancel</button>
            <div class="progress-bar">
                <div class="progress-fill" style="width: @(_progress.PercentComplete)%"></div>
            </div>
            <p class="scan-status">@_progress.CurrentPage -- @_progress.CurrentPayload (@_progress.CompletedPayloads/@_progress.TotalPayloads)</p>
        }
        else
        {
            <button class="btn btn-primary" @onclick="StartScan">Start Scan</button>
        }
    </div>

    <div class="scan-results">
        <h4>Results (@_results.Count findings)</h4>
        <table class="results-table">
            <thead>
                <tr>
                    <th>Severity</th>
                    <th>Type</th>
                    <th>Page</th>
                    <th>Payload</th>
                    <th>Evidence</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _results)
                {
                    <tr class="severity-@r.Severity.ToString().ToLower()">
                        <td><span class="severity-badge @r.Severity.ToString().ToLower()">@r.Severity</span></td>
                        <td>@r.VulnerabilityType</td>
                        <td>@r.PageUrl</td>
                        <td class="payload-cell">@Truncate(r.Payload, 40)</td>
                        <td class="evidence-cell">@Truncate(r.Evidence, 60)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string _targetPages = "/login\n/search\n/guestbook";
    private bool _enableXss = true, _enableSqli = true, _enableCmdInj = true, _enablePathTrav = true;
    private int _delayMs = 500;
    private ScanProgress? _progress;
    private List<ScanResult> _results = new();
    private CancellationTokenSource? _cts;

    private async Task StartScan()
    {
        _cts = new CancellationTokenSource();
        _results.Clear();

        var categories = new List<string>();
        if (_enableXss) categories.Add("XSS");
        if (_enableSqli) categories.Add("SQLi");
        if (_enableCmdInj) categories.Add("CommandInjection");
        if (_enablePathTrav) categories.Add("PathTraversal");

        var options = new ScanOptions
        {
            TargetPages = _targetPages.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList(),
            EnabledCategories = categories,
            DelayBetweenPayloadsMs = _delayMs
        };

        VulnScanner.OnProgressChanged += OnProgress;
        VulnScanner.OnVulnerabilityFound += OnVulnFound;

        _results = await VulnScanner.ScanAsync(AppState.TargetConfig, options, _cts.Token);
        AppState.ScanResults.AddRange(_results);

        VulnScanner.OnProgressChanged -= OnProgress;
        VulnScanner.OnVulnerabilityFound -= OnVulnFound;
    }

    private void CancelScan() => _cts?.Cancel();

    private void OnProgress(ScanProgress p) { _progress = p; InvokeAsync(StateHasChanged); }
    private void OnVulnFound(ScanResult r) { _results.Add(r); InvokeAsync(StateHasChanged); }

    private string Truncate(string s, int max) => s.Length > max ? s[..max] + "..." : s;

    public void Dispose() => _cts?.Dispose();
}
