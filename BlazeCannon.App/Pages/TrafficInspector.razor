@page "/traffic"
@using BlazeCannon.Core.Interfaces
@using BlazeCannon.Core.Models
@inject IMitmProxy Proxy
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Traffic Inspector - BlazeCannon</PageTitle>

<h2>Traffic Inspector</h2>

<div class="toolbar">
    <div class="proxy-info">
        <span class="status-dot connected"></span>
        Forward proxy on port <strong>@_proxyPort</strong> — configure your browser to proxy through this port
    </div>
    <button class="btn btn-secondary" @onclick="Clear">Clear</button>
    <button class="btn btn-secondary" @onclick="ResetColumns">Reset Columns</button>
    <button class="btn btn-secondary" @onclick="ExportJson" disabled="@(!Filtered.Any())">Export JSON</button>
    <button class="btn btn-secondary" @onclick="ExportCsv" disabled="@(!Filtered.Any())">Export CSV</button>
    <span class="message-count">@_messages.Count messages</span>
    <div class="filter-group">
        <select @bind="_directionFilter" class="form-control dark-input">
            <option value="">All</option>
            <option value="ClientToServer">Client → Server</option>
            <option value="ServerToClient">Server → Client</option>
        </select>
        <select @bind="_typeFilter" class="form-control dark-input">
            <option value="">All Types</option>
            @foreach (var t in Enum.GetValues<BlazorMessageType>())
            {
                <option value="@t">@t</option>
            }
        </select>
        <input type="text" @bind="_search" @bind:event="oninput" placeholder="Search..." class="form-control dark-input" />
    </div>
</div>

<div class="traffic-container">
    <div class="message-list">
        <table class="traffic-table">
            <thead>
                <tr>
                    @foreach (var col in _columnOrder)
                    {
                        var key = col;
                        <th draggable="true"
                            class="@(_dragOverKey == key ? "drag-over" : "")"
                            @ondragstart="@(() => OnDragStart(key))"
                            @ondragover="@(e => OnDragOver(e, key))"
                            @ondragover:preventDefault="true"
                            @ondragleave="@(() => _dragOverKey = null)"
                            @ondrop="@(() => OnDrop(key))"
                            @ondrop:preventDefault="true">
                            <span class="col-grip">⋮⋮</span> @ColumnLabel(key)
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var msg in Filtered)
                {
                    <tr class="@(msg == _selected ? "selected" : "")" @onclick="() => _selected = msg">
                        @foreach (var col in _columnOrder)
                        {
                            @RenderCell(col, msg)
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_selected != null)
    {
        <div class="detail-panel">
            <h4>Detail</h4>
            <div class="detail-field"><strong>Direction:</strong> @_selected.Direction</div>
            <div class="detail-field"><strong>Type:</strong> @_selected.MessageType</div>
            <div class="detail-field"><strong>Method:</strong> @(_selected.HubMethod ?? "N/A")</div>
            <div class="detail-field"><strong>Host:</strong> @(_selected.Host ?? "N/A")</div>
            <div class="detail-field"><strong>Hub:</strong> @(_selected.HubPath ?? "N/A")</div>
            <div class="detail-field"><strong>Transport:</strong> @(_selected.Transport ?? "N/A")</div>
            <div class="detail-field"><strong>Session:</strong> @(_selected.SessionId ?? "N/A")</div>
            <div class="detail-field"><strong>Time:</strong> @_selected.Timestamp</div>
            @if (_selected.DecodedArguments != null)
            {
                <div class="detail-field"><strong>Arguments:</strong></div>
                <pre class="args-display">@System.Text.Json.JsonSerializer.Serialize(_selected.DecodedArguments, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
            }
            <div class="detail-field"><strong>Raw:</strong></div>
            <pre class="raw-display">@_selected.RawPayload</pre>
        </div>
    }
</div>

@code {
    private List<BlazorMessage> _messages = new();
    private BlazorMessage? _selected;
    private string _directionFilter = "";
    private string _typeFilter = "";
    private string _search = "";
    private int _proxyPort;

    // Column reordering state
    private static readonly string[] DefaultColumnOrder =
        { "time", "dir", "type", "method", "host", "hub", "transport", "preview" };
    private List<string> _columnOrder = DefaultColumnOrder.ToList();
    private string? _draggingKey;
    private string? _dragOverKey;
    private const string ColumnOrderStorageKey = "blazecannon.traffic.columnOrder";

    private IEnumerable<BlazorMessage> Filtered
    {
        get
        {
            var q = _messages.AsEnumerable();
            if (!string.IsNullOrEmpty(_directionFilter))
                q = q.Where(m => m.Direction == Enum.Parse<MessageDirection>(_directionFilter));
            if (!string.IsNullOrEmpty(_typeFilter))
                q = q.Where(m => m.MessageType == Enum.Parse<BlazorMessageType>(_typeFilter));
            if (!string.IsNullOrEmpty(_search))
                q = q.Where(m => m.RawPayload.Contains(_search, StringComparison.OrdinalIgnoreCase)
                    || (m.HubMethod?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (m.Host?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (m.HubPath?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));
            return q.TakeLast(500);
        }
    }

    protected override void OnInitialized()
    {
        _proxyPort = int.Parse(Environment.GetEnvironmentVariable("BLAZECANNON_PROXY_PORT") ?? "5001");
        Proxy.OnMessageIntercepted += OnMessage;

        foreach (var msg in Proxy.CapturedMessages)
            _messages.Add(msg);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var stored = await JS.InvokeAsync<string?>("localStorage.getItem", ColumnOrderStorageKey);
                if (!string.IsNullOrWhiteSpace(stored))
                {
                    var parsed = stored.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
                    // Sanity: must contain the same set of keys as DefaultColumnOrder
                    if (parsed.Count == DefaultColumnOrder.Length &&
                        parsed.All(DefaultColumnOrder.Contains))
                    {
                        _columnOrder = parsed;
                        StateHasChanged();
                    }
                }
            }
            catch { /* localStorage unavailable — ignore */ }
        }
    }

    private void OnDragStart(string key) => _draggingKey = key;

    private void OnDragOver(Microsoft.AspNetCore.Components.Web.DragEventArgs _, string key)
    {
        _dragOverKey = key;
    }

    private async Task OnDrop(string targetKey)
    {
        if (_draggingKey == null || _draggingKey == targetKey)
        {
            _draggingKey = null; _dragOverKey = null;
            return;
        }
        var fromIdx = _columnOrder.IndexOf(_draggingKey);
        var toIdx = _columnOrder.IndexOf(targetKey);
        if (fromIdx < 0 || toIdx < 0) return;
        _columnOrder.RemoveAt(fromIdx);
        _columnOrder.Insert(toIdx, _draggingKey);
        _draggingKey = null;
        _dragOverKey = null;
        await PersistColumnOrder();
    }

    private async Task ResetColumns()
    {
        _columnOrder = DefaultColumnOrder.ToList();
        await PersistColumnOrder();
    }

    private async Task PersistColumnOrder()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", ColumnOrderStorageKey, string.Join(',', _columnOrder));
        }
        catch { }
    }

    private static string ColumnLabel(string key) => key switch
    {
        "time" => "Time",
        "dir" => "Dir",
        "type" => "Type",
        "method" => "Method",
        "host" => "Host",
        "hub" => "Blazor Hub",
        "transport" => "Transport",
        "preview" => "Preview",
        _ => key
    };

    private RenderFragment RenderCell(string key, BlazorMessage msg) => builder =>
    {
        builder.OpenElement(0, "td");
        switch (key)
        {
            case "time":
                builder.AddContent(1, msg.Timestamp.ToString("HH:mm:ss.fff"));
                break;
            case "dir":
                builder.AddAttribute(2, "class", msg.Direction == MessageDirection.ClientToServer ? "dir-out" : "dir-in");
                builder.AddContent(3, msg.Direction == MessageDirection.ClientToServer ? "→" : "←");
                break;
            case "type":
                builder.AddContent(4, msg.MessageType.ToString());
                break;
            case "method":
                builder.AddContent(5, msg.HubMethod ?? "-");
                break;
            case "host":
                builder.AddContent(6, msg.Host ?? "-");
                break;
            case "hub":
                builder.AddContent(7, msg.HubPath ?? "-");
                break;
            case "transport":
                builder.AddContent(8, msg.Transport ?? "-");
                break;
            case "preview":
                builder.AddAttribute(9, "class", "payload-preview");
                builder.AddContent(10, Truncate(msg.RawPayload, 80));
                break;
        }
        builder.CloseElement();
    };

    private void OnMessage(BlazorMessage msg)
    {
        _messages.Add(msg);
        InvokeAsync(StateHasChanged);
    }

    private void Clear() { _messages.Clear(); _selected = null; Proxy.ClearMessages(); }
    private string Truncate(string s, int max) => s.Length > max ? s[..max] + "..." : s;

    private async Task ExportJson()
    {
        var snapshot = Filtered.ToList();
        var json = System.Text.Json.JsonSerializer.Serialize(snapshot, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("blazeCannonDownload", $"blazecannon-traffic-{DateTime.UtcNow:yyyyMMdd-HHmmss}.json", "application/json", json);
    }

    private async Task ExportCsv()
    {
        var snapshot = Filtered.ToList();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Timestamp,Direction,Type,HubMethod,Host,HubPath,Transport,SessionId,InvocationId,SequenceId,PayloadLength,RawPayload");
        foreach (var m in snapshot)
        {
            sb.Append(m.Timestamp.ToString("O")).Append(',');
            sb.Append(m.Direction).Append(',');
            sb.Append(m.MessageType).Append(',');
            sb.Append(CsvEscape(m.HubMethod)).Append(',');
            sb.Append(CsvEscape(m.Host)).Append(',');
            sb.Append(CsvEscape(m.HubPath)).Append(',');
            sb.Append(CsvEscape(m.Transport)).Append(',');
            sb.Append(CsvEscape(m.SessionId)).Append(',');
            sb.Append(CsvEscape(m.InvocationId)).Append(',');
            sb.Append(m.SequenceId?.ToString() ?? "").Append(',');
            sb.Append(m.RawBinaryPayload?.Length ?? m.RawPayload.Length).Append(',');
            sb.AppendLine(CsvEscape(m.RawPayload));
        }
        await JS.InvokeVoidAsync("blazeCannonDownload", $"blazecannon-traffic-{DateTime.UtcNow:yyyyMMdd-HHmmss}.csv", "text/csv", sb.ToString());
    }

    private static string CsvEscape(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        var needsQuotes = value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r');
        var escaped = value.Replace("\"", "\"\"");
        return needsQuotes ? $"\"{escaped}\"" : escaped;
    }

    public void Dispose() => Proxy.OnMessageIntercepted -= OnMessage;
}
