@page "/"
@using BlazeCannon.App.Services
@using BlazeCannon.Core.Interfaces
@using BlazeCannon.Core.Models
@inject AppStateService AppState
@inject ITrafficProxy Proxy

<PageTitle>BlazeCannon - Dashboard</PageTitle>

<div class="dashboard">
    <h1 class="title">BlazeCannon</h1>
    <p class="subtitle">Blazor Server Penetration Testing Framework</p>

    <div class="config-panel">
        <h3>Target Configuration</h3>
        <div class="form-group">
            <label>Target URL</label>
            <input type="text" @bind="AppState.TargetConfig.BaseUrl" class="form-control dark-input" placeholder="http://localhost:5000" />
        </div>
        <div class="form-group">
            <label>Hub Path</label>
            <input type="text" @bind="AppState.TargetConfig.BlazorHubPath" class="form-control dark-input" placeholder="/_blazor" />
        </div>
        <div class="form-group">
            <label>Auth Cookie (optional)</label>
            <input type="text" @bind="AppState.TargetConfig.AuthCookie" class="form-control dark-input" placeholder=".AspNetCore.Cookies=..." />
        </div>
        <div class="status-bar">
            <span class="status-dot @(AppState.IsConnected ? "connected" : "disconnected")"></span>
            @(AppState.IsConnected ? "Connected" : "Disconnected")

            @if (!AppState.IsConnected)
            {
                <button class="btn btn-primary" style="margin-left: 1rem;" @onclick="Connect" disabled="@_connecting">
                    @(_connecting ? "Connecting..." : "Connect")
                </button>
            }
            else
            {
                <button class="btn btn-danger" style="margin-left: 1rem;" @onclick="Disconnect">Disconnect</button>
            }
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="status-bar" style="color: var(--accent-red); margin-top: 0.5rem;">@_error</div>
        }
    </div>

    <div class="quick-actions">
        <div class="action-card" @onclick='() => Nav.NavigateTo("/traffic")'>
            <h4>Traffic Inspector</h4>
            <p>Monitor SignalR/WebSocket traffic in real-time</p>
            <span class="badge">@AppState.Messages.Count messages</span>
        </div>
        <div class="action-card" @onclick='() => Nav.NavigateTo("/workbench")'>
            <h4>Payload Workbench</h4>
            <p>Craft and inject Blazor protocol messages</p>
        </div>
        <div class="action-card" @onclick='() => Nav.NavigateTo("/scanner")'>
            <h4>Vulnerability Scanner</h4>
            <p>Automated scanning with built-in payloads</p>
            <span class="badge">@AppState.ScanResults.Count findings</span>
        </div>
        <div class="action-card" @onclick='() => Nav.NavigateTo("/browser")'>
            <h4>Browser Engine</h4>
            <p>Native Blazor rendering via Chromium</p>
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _connecting;
    private string? _error;

    private async Task Connect()
    {
        _connecting = true;
        _error = null;
        try
        {
            await Proxy.ConnectAsync(AppState.TargetConfig);
            AppState.IsConnected = true;
            AppState.NotifyStateChanged();
        }
        catch (Exception ex)
        {
            _error = $"Connection failed: {ex.Message}";
            AppState.IsConnected = false;
        }
        _connecting = false;
    }

    private async Task Disconnect()
    {
        await Proxy.DisconnectAsync();
        AppState.IsConnected = false;
        _error = null;
        AppState.NotifyStateChanged();
    }
}
