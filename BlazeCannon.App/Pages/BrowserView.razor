@page "/browser"
@using BlazeCannon.App.Services
@using BlazeCannon.Core.Interfaces
@using BlazeCannon.Core.Models
@inject AppStateService AppState
@inject IBrowserEngine Browser
@implements IDisposable

<PageTitle>Browser - BlazeCannon</PageTitle>

<h2>Browser Engine</h2>

<div class="browser-layout">
    <div class="browser-main">
        <div class="browser-toolbar">
            <input type="text" @bind="_url" class="form-control dark-input url-bar" placeholder="http://localhost:5000" />
            <button class="btn btn-primary" @onclick="Navigate" disabled="@(!_isLaunched)">Go</button>
            @if (!_isLaunched)
            {
                <button class="btn btn-secondary" @onclick="Launch">Launch Browser</button>
            }
            else
            {
                <button class="btn btn-secondary" @onclick="TakeScreenshot">Screenshot</button>
                <button class="btn btn-secondary" @onclick="DiscoverFields">Discover Fields</button>
            }
        </div>

        <div class="browser-viewport">
            @if (_screenshot != null)
            {
                <img src="data:image/png;base64,@Convert.ToBase64String(_screenshot)" class="screenshot" alt="Page screenshot" />
            }
            else
            {
                <div class="empty-viewport">Launch browser and navigate to see the page</div>
            }
        </div>

        @if (_fields.Any())
        {
            <div class="fields-panel">
                <h4>Discovered Fields</h4>
                <table class="fields-table">
                    <thead><tr><th>Tag</th><th>Type</th><th>ID</th><th>Name</th><th>Action</th></tr></thead>
                    <tbody>
                        @foreach (var f in _fields)
                        {
                            <tr>
                                <td>@f.TagName</td>
                                <td>@(f.Type ?? "-")</td>
                                <td>@(f.Id ?? "-")</td>
                                <td>@(f.Name ?? "-")</td>
                                <td>
                                    <input type="text" @bind="_fillValues[_fields.IndexOf(f)]" class="form-control dark-input sm" placeholder="value" />
                                    <button class="btn btn-sm btn-primary" @onclick="() => FillField(f)">Fill</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="ws-sidebar">
        <h4>WebSocket Traffic</h4>
        <div class="ws-messages">
            @foreach (var msg in _wsMessages.TakeLast(100))
            {
                <div class="ws-msg @(msg.Direction == MessageDirection.ClientToServer ? "ws-out" : "ws-in")">
                    <span class="ws-dir">@(msg.Direction == MessageDirection.ClientToServer ? "->" : "<-")</span>
                    <span class="ws-type">@msg.MessageType</span>
                    <span class="ws-preview">@Truncate(msg.RawPayload, 60)</span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string _url = "http://localhost:5000";
    private bool _isLaunched;
    private byte[]? _screenshot;
    private List<BlazorElement> _fields = new();
    private List<string> _fillValues = new();
    private List<BlazorMessage> _wsMessages = new();

    private async Task Launch()
    {
        await Browser.LaunchAsync();
        Browser.OnWebSocketMessage += OnWsMessage;
        _isLaunched = true;
    }

    private async Task Navigate()
    {
        await Browser.NavigateAsync(_url);
        await Task.Delay(1000);
        await TakeScreenshot();
    }

    private async Task TakeScreenshot()
    {
        _screenshot = await Browser.ScreenshotAsync();
    }

    private async Task DiscoverFields()
    {
        _fields = await Browser.DiscoverFieldsAsync();
        _fillValues = _fields.Select(_ => "").ToList();
    }

    private async Task FillField(BlazorElement field)
    {
        var idx = _fields.IndexOf(field);
        var selector = !string.IsNullOrEmpty(field.Id) ? $"#{field.Id}" :
                       !string.IsNullOrEmpty(field.Name) ? $"[name='{field.Name}']" :
                       $"{field.TagName}[type='{field.Type}']";
        await Browser.FillFieldAsync(selector, _fillValues[idx]);
        await TakeScreenshot();
    }

    private void OnWsMessage(BlazorMessage msg)
    {
        _wsMessages.Add(msg);
        InvokeAsync(StateHasChanged);
    }

    private string Truncate(string s, int max) => s.Length > max ? s[..max] + "..." : s;

    public void Dispose() => Browser.OnWebSocketMessage -= OnWsMessage;
}
